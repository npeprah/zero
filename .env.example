# Tastytrade API Credentials
# Get these from your Tastytrade account settings

TASTYTRADE_EMAIL=your_email@example.com
TASTYTRADE_PASSWORD=your_password
TASTYTRADE_ACCOUNT_ID=your_account_id

# Optional: Override defaults
BOT_SANDBOX_MODE=true
BOT_RISK_PER_TRADE=0.01
BOT_TARGET_DELTA=0.20
BOT_SPREAD_WIDTH=5
BOT_GEX_ENABLED=true
